ObjC.import("Cocoa")

const statePath = $.NSProcessInfo.processInfo.arguments.objectAtIndex(4).js
const app = $.NSApplication.sharedApplication
const width = 220
const height = 70

ObjC.registerSubclass({
  name: "XRayTick",
  methods: {
    "tick:": {
      types: ["void", ["id"]],
      implementation: function () {
        if (!win.isVisible()) {
          app.terminate(null)
          return
        }
        try {
          const text = $.NSString.stringWithContentsOfFileEncodingError(statePath, $.NSUTF8StringEncoding, null)
          if (!text) return
          const state = JSON.parse(ObjC.unwrap(text))
          label.setStringValue(`${state.label} llm calls: ${state.calls}`)
        } catch (_) {}
      },
    },
  },
})

app.setActivationPolicy($.NSApplicationActivationPolicyAccessory)

const screen = $.NSScreen.mainScreen.visibleFrame
const rect = $.NSMakeRect(
  screen.origin.x + screen.size.width - width - 24,
  screen.origin.y + screen.size.height - height - 24,
  width,
  height,
)
const style = $.NSWindowStyleMaskTitled | $.NSWindowStyleMaskClosable | $.NSWindowStyleMaskNonactivatingPanel
const win = $.NSPanel.alloc.initWithContentRectStyleMaskBackingDefer(rect, style, $.NSBackingStoreBuffered, false)

win.setLevel($.NSFloatingWindowLevel)
win.setCollectionBehavior($.NSWindowCollectionBehaviorCanJoinAllSpaces | $.NSWindowCollectionBehaviorFullScreenAuxiliary)
win.setTitle("x-ray")
win.setOpaque(false)
win.setBackgroundColor($.NSColor.colorWithCalibratedWhiteAlpha(0.08, 0.92))

const label = $.NSTextField.alloc.initWithFrame($.NSMakeRect(12, 19, width - 24, 30))
label.setStringValue("codex llm calls: 0")
label.setTextColor($.NSColor.whiteColor)
label.setBezeled(false)
label.setDrawsBackground(false)
label.setEditable(false)
label.setSelectable(false)
label.setAlignment($.NSTextAlignmentCenter)
label.setFont($.NSFont.monospacedDigitSystemFontOfSizeWeight(17, $.NSFontWeightSemibold))
win.contentView.addSubview(label)

const target = $.XRayTick.alloc.init
$.NSTimer.scheduledTimerWithTimeIntervalTargetSelectorUserInfoRepeats(0.25, target, "tick:", null, true)

win.makeKeyAndOrderFront(null)
app.run()
